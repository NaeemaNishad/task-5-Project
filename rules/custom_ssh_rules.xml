<group name="syslog,sshd,">
  <rule id="5710" level="5">
    <if_sid>5700</if_sid>
    <match>Failed password|Invalid user</match>
    <description>sshd: Single authentication failure attempt.</description>
  </rule>

  <rule id="5712" level="10">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <frequency>8</frequency>
    <timeframe>30</timeframe>
    <description>sshd: High-velocity parallel brute-force attack detected.</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>
</group>
